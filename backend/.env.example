# Copy this file to .env and fill in your values
# cp .env.example .env

PORT=5000
NODE_ENV=development

# Generate a strong random string — used to sign JWT tokens
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ── Mila AI Assistant (optional) ────────────────────────
# Get your key from https://platform.openai.com/api-keys
# Leave blank to use Mila's built-in local knowledge base (no key needed)
OPENAI_API_KEY=
